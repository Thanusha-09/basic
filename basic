#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    char ch;
    char s[100];
    char sen[100];
    
    // 1. Read and print a single character
    scanf("%c", &ch);
    printf("%c\n", ch);
    
    // 2. Read and print a single word
    scanf("%s", s);
    printf("%s\n", s);
    
    // 3. Consume the leftover newline character to prevent buffer issues
    scanf("\n");
    
    // 4. Read and print the full sentence
    scanf("%[^\n]%*c", sen);
    printf("%s", sen);
    
    return 0;
}
